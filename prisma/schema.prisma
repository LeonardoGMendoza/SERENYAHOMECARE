// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id          Int       @id @default(autoincrement())
  name        String
  email       String    @unique
  password    String
  role        String    @default("admin")
  pacienteId  Int?
  paciente    Paciente? @relation(fields: [pacienteId], references: [id], onDelete: SetNull)
  createdAt   DateTime  @default(now())
}

model Paciente {
  id           Int      @id @default(autoincrement())
  nome         String
  telefone     String?
  endereco     String?
  diagnostico  String?
  alergias     String?
  medicacoes   String?
  grauDependencia String?
  observacoesEnfermagem String?
  status       String   @default("Ativo")
  plano        String?
  users        User[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Profissional {
  id         Int      @id @default(autoincrement())
  nome       String
  telefone   String?
  cargo      String
  status     String   @default("Ativo")
  documento  String?
  createdAt  DateTime @default(now())
}

model Lead {
  id        Int      @id @default(autoincrement())
  nome      String
  telefone  String   @unique
  origem    String?
  interesse String?
  status    String   @default("Novo")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Atendimento {
  id          Int      @id @default(autoincrement())
  pacienteId  Int
  profissionalId Int
  data        DateTime
  tipo        String
  observacoes String?
  createdAt   DateTime @default(now())
}

model Candidato {
  id           Int      @id @default(autoincrement())
  nome         String
  email        String
  telefone     String
  cargo        String
  experiencia  String?
  cidade       String?
  status       String   @default("Novo")
  curriculoUrl String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model RelatorioDiario {
  id                    Int      @id @default(autoincrement())
  cuidadorId            Int
  cuidadorNome          String
  pacienteId            Int
  pacienteNome          String
  data                  DateTime @default(now())
  turno                 String?
  pressaoArterial       String?
  temperatura           String?
  frequenciaCardiaca    String?
  glicemia              String?
  banho                 Boolean  @default(false)
  alimentacao           String?
  eliminacoes           String?
  medicacoes            String?
  relatoPlantao         String?
  createdAt             DateTime @default(now())
}


